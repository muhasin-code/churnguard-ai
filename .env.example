# ============================================================================
# ChurnGuard AI - API Configuration
# ============================================================================

# ============================================================================
# MLflow Registry Configuration
# ============================================================================
MLFLOW_TRACKING_URI=http://your-mlflow-server:5000
MLFLOW_REGISTRY_URI=http://your-mlflow-registry-server:5000
MODEL_NAME=your-model-name
MODEL_STAGE=

# ============================================================================
# API Server Configuration
# ============================================================================
API_TITLE=
API_VERSION=
API_DESCRIPTION=
API_HOST=
API_PORT=
API_WORKERS=
API_RELOAD=

# ============================================================================
# Model Inference Configuration
# ============================================================================
PREDICTION_THRESHOLD=
BATCH_SIZE_LIMIT=
ENABLE_PROBABILITY_OUTPUT=
ENABLE_FEATURE_IMPORTANCE=

# ============================================================================
# Feature Engineering
# ============================================================================
FEATURE_PIPELINE_PATH=models/feature_pipeline.pkl

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO # DEBUG,INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/api.log
LOG_FORMAT=json # json or text
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=
DEBUG=

# ============================================================================
# Security 
# ============================================================================
ENABLE_API_KEY=
CORS_ENABLED=
CORS_ORIGINS=

# ============================================================================
# Performance & Limits
# ============================================================================
REQUEST_TIMEOUT_SECONDS=
MAX_CONCURRENT_RESPONSE=
ENABLE_RESPONSE_CACHE=